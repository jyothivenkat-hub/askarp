# Copy this file to .env for local testing, or add the same values in Vercel.
# Never commit real API keys.

# Required for server-side model answers through /api/chat.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MAX_TOKENS=800

# Optional. YouTube transcript extraction is host-sensitive and may fail on
# datacenter hosts without a provider/key. Leave blank for local watch-page
# fallback, or configure your own compliant transcript provider path.
YOUTUBE_INNERTUBE_API_KEY=
